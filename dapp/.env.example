# ─── REQUIRED ────────────────────────────────────────────────────────────────

# WalletConnect Cloud projectId (https://cloud.reown.com/).
# Production builds must NOT ship the placeholder value below.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=


# ─── MAINNET (production) ────────────────────────────────────────────────────
# Fill these in after running `forge script script/DeployMainnet.s.sol`.
# Use restricted Alchemy/Infura keys with domain allowlisting in the dashboard —
# every NEXT_PUBLIC_* var is embedded in the client JS bundle at build time.

NEXT_PUBLIC_MAINNET_RPC_URL=
# Optional dedicated logs RPC. Free-tier Alchemy throttles eth_getLogs hard;
# a separate URL (paid plan or llamarpc) keeps the Chronicle / Throne Room
# event scans responsive. Default falls back to https://eth.llamarpc.com.
NEXT_PUBLIC_MAINNET_LOGS_RPC=
# Block at which the hook contract was deployed. Used as fromBlock for log
# scans; without it the dapp scans from genesis and times out on free tiers.
NEXT_PUBLIC_MAINNET_DEPLOY_BLOCK=

NEXT_PUBLIC_MAINNET_KOTH=
NEXT_PUBLIC_MAINNET_HOOK=
NEXT_PUBLIC_MAINNET_ROUTER=
NEXT_PUBLIC_MAINNET_SOUL=
NEXT_PUBLIC_MAINNET_SCROLL=
# PoolManager is the canonical Uniswap v4 deployment. Leave empty to use the
# default coded in dapp/lib/contracts.ts (verified against docs.uniswap.org).
NEXT_PUBLIC_MAINNET_POOL_MANAGER=


# ─── SEPOLIA (staging / QA) ──────────────────────────────────────────────────

NEXT_PUBLIC_SEPOLIA_RPC_URL=
NEXT_PUBLIC_SEPOLIA_LOGS_RPC=
NEXT_PUBLIC_SEPOLIA_DEPLOY_BLOCK=

NEXT_PUBLIC_SEPOLIA_KOTH=
NEXT_PUBLIC_SEPOLIA_HOOK=
NEXT_PUBLIC_SEPOLIA_ROUTER=
NEXT_PUBLIC_SEPOLIA_SOUL=
NEXT_PUBLIC_SEPOLIA_SCROLL=
NEXT_PUBLIC_SEPOLIA_POOL_MANAGER=


# ─── LOCAL ANVIL (dev) ───────────────────────────────────────────────────────

NEXT_PUBLIC_LOCAL_KOTH=
NEXT_PUBLIC_LOCAL_HOOK=
NEXT_PUBLIC_LOCAL_ROUTER=
NEXT_PUBLIC_LOCAL_SOUL=
NEXT_PUBLIC_LOCAL_SCROLL=
NEXT_PUBLIC_LOCAL_POOL_MANAGER=
