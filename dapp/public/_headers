# Cloudflare Pages reads this file to attach response headers to served
# routes. Same security policy that used to live in next.config.ts under
# `headers()` — switched to this format when we moved to static export.

/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains
